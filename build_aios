#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SRC_DIR="$ROOT_DIR/src"
PROJECT_CONFIG_PATH="$SRC_DIR/bucky_project.yaml"
IMAGE_NAME="${IMAGE_NAME:-paios/aios}"
VERSION_FILE="$SRC_DIR/VERSION"
VERSION_TAG="${VERSION_TAG:-}"
PLATFORMS=("amd64" "aarch64")
RUNTIME_PACKAGES=("tmux" "bash" "ca-certificates")
WORKSPACE_PACKAGES=("python3" "python3-pip" "python3-venv" "nodejs" "npm" "git")
EXTRA_APT_PACKAGES=()
PUSH=0
INSTALL_WORKSPACE_TOOLS=1

usage() {
  cat <<'EOF'
Usage: ./build_aios [--push] [--image <name>] [--tag <tag>] [--runtime-only] [--apt-package <name>]

Builds the OpenDAN binary with cargo for:
  - amd64   -> x86_64-unknown-linux-musl
  - aarch64 -> aarch64-unknown-linux-musl

Then packages each binary into an Ubuntu-based Docker image:
  - <image>:<tag>-amd64
  - <image>:latest-amd64
  - <image>:<tag>-aarch64
  - <image>:latest-aarch64

Options:
  --push          Push arch-specific images and create multi-arch manifests
  --image <name>  Override image name, default: paios/aios
  --tag <tag>     Override version tag, default: src/VERSION
  --runtime-only  Install only required runtime dependencies in the image
  --apt-package   Add an extra apt package to the image; can be repeated
  -h, --help      Show this help
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --push)
      PUSH=1
      shift
      ;;
    --image)
      IMAGE_NAME="$2"
      shift 2
      ;;
    --tag)
      VERSION_TAG="$2"
      shift 2
      ;;
    --runtime-only)
      INSTALL_WORKSPACE_TOOLS=0
      shift
      ;;
    --apt-package)
      EXTRA_APT_PACKAGES+=("$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

log() {
  printf '[build_aios] %s\n' "$*"
}

prepare_docker_config() {
  local workspace_tmp_root="$1"
  local docker_config_dir="${DOCKER_CONFIG:-$HOME/.docker}"
  local docker_config_path="$docker_config_dir/config.json"
  local sanitized_dir="$workspace_tmp_root/docker-config"
  local sanitized_config_path="$sanitized_dir/config.json"
  local python_bin
  local sanitize_result

  if [[ "$(uname -s)" != "Linux" ]]; then
    return
  fi

  if [[ ! -f "$docker_config_path" ]]; then
    return
  fi

  python_bin="$(resolve_python)"
  sanitize_result="$(
    "$python_bin" - "$docker_config_path" "$sanitized_config_path" <<'PY'
import json
import os
import shutil
import sys

config_path = sys.argv[1]
output_path = sys.argv[2]

with open(config_path, "r", encoding="utf-8") as fh:
    config = json.load(fh)

removed = []

def helper_binary(helper):
    return f"docker-credential-{helper}"

def helper_missing(helper):
    return shutil.which(helper_binary(helper)) is None

creds_store = config.get("credsStore")
if isinstance(creds_store, str) and helper_missing(creds_store):
    removed.append(f"credsStore={creds_store}")
    config.pop("credsStore", None)

cred_helpers = config.get("credHelpers")
if isinstance(cred_helpers, dict):
    sanitized_helpers = {}
    for registry, helper in cred_helpers.items():
        if isinstance(helper, str) and helper_missing(helper):
            removed.append(f"credHelpers[{registry}]={helper}")
            continue
        sanitized_helpers[registry] = helper
    if sanitized_helpers:
        config["credHelpers"] = sanitized_helpers
    else:
        config.pop("credHelpers", None)

if not removed:
    print("UNCHANGED")
    raise SystemExit(0)

os.makedirs(os.path.dirname(output_path), exist_ok=True)
with open(output_path, "w", encoding="utf-8") as fh:
    json.dump(config, fh, indent=2)
    fh.write("\n")

print("SANITIZED")
for item in removed:
    print(item)
PY
  )"

  if [[ "$sanitize_result" == UNCHANGED* ]]; then
    return
  fi

  export DOCKER_CONFIG="$sanitized_dir"
  log "Detected missing Docker credential helper(s); using sanitized DOCKER_CONFIG at $DOCKER_CONFIG"
  while IFS= read -r line; do
    [[ "$line" == "SANITIZED" || -z "$line" ]] && continue
    log "  removed $line"
  done <<< "$sanitize_result"
}

resolve_version_tag() {
  if [[ -n "$VERSION_TAG" ]]; then
    return
  fi

  if [[ ! -f "$VERSION_FILE" ]]; then
    echo "Missing version file: $VERSION_FILE" >&2
    exit 1
  fi

  VERSION_TAG="$(tr -d '[:space:]' < "$VERSION_FILE")"

  if [[ -z "$VERSION_TAG" ]]; then
    echo "Version file is empty: $VERSION_FILE" >&2
    exit 1
  fi
}

package_list_to_string() {
  local IFS=' '
  printf '%s' "$*"
}

render_dockerfile() {
  local output_path="$1"
  local -a apt_packages=("${RUNTIME_PACKAGES[@]}")

  if [[ "$INSTALL_WORKSPACE_TOOLS" -eq 1 ]]; then
    apt_packages+=("${WORKSPACE_PACKAGES[@]}")
  fi

  if [[ ${#EXTRA_APT_PACKAGES[@]} -gt 0 ]]; then
    apt_packages+=("${EXTRA_APT_PACKAGES[@]}")
  fi

  {
    cat <<'EOF'
FROM ubuntu:24.04

ARG TARGET_ARCH

LABEL org.opencontainers.image.title="AIOS" \
      org.opencontainers.image.description="OpenDAN runtime image for paios/aios" \
      org.opencontainers.image.vendor="BuckyOS DAO"

WORKDIR /opt/buckyos

# Required by OpenDAN runtime and common agent workspace workflows.
RUN apt-get update && apt-get install -y --no-install-recommends \
EOF

    for package in "${apt_packages[@]}"; do
      printf '    %s \\\n' "$package"
    done

    cat <<'EOF'
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/buckyos/bin/opendan

COPY opendan /opt/buckyos/bin/opendan/opendan

ENV AIOS_TARGET_ARCH="${TARGET_ARCH}"

EXPOSE 3180

ENTRYPOINT ["/opt/buckyos/bin/opendan/opendan"]
EOF
  } > "$output_path"
}

resolve_python() {
  if [[ -x "$ROOT_DIR/venv/bin/python" ]]; then
    echo "$ROOT_DIR/venv/bin/python"
    return
  fi

  if [[ -x "$ROOT_DIR/venv/bin/python3" ]]; then
    echo "$ROOT_DIR/venv/bin/python3"
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    command -v python3
    return
  fi

  echo "python3 not found" >&2
  exit 1
}

load_build_context() {
  local python_bin="$1"
  local rust_target="$2"

  "$python_bin" - "$PROJECT_CONFIG_PATH" "$rust_target" <<'PY'
import contextlib
import io
import sys

config_path = sys.argv[1]
target = sys.argv[2]

with contextlib.redirect_stdout(io.StringIO()):
    from buckyos_devkit.build_rust import get_cross_compile_env_vars_by_target, get_env_vars_by_target
    from buckyos_devkit.project import BuckyProject

    project = BuckyProject.from_file(config_path)

    env = {}
    env.update(project.rust_env)
    env.update(get_env_vars_by_target(target))

    cross_env = get_cross_compile_env_vars_by_target(target)
    if cross_env:
        env.update(cross_env)

print(f"RUST_TARGET={target}")
for key, value in env.items():
    print(f"{key}={value}")
PY
}

resolve_rust_target() {
  local arch="$1"

  case "$arch" in
    amd64)
      echo "x86_64-unknown-linux-musl"
      ;;
    aarch64)
      echo "aarch64-unknown-linux-musl"
      ;;
    *)
      echo "Unsupported arch: $arch" >&2
      exit 1
      ;;
  esac
}

resolve_aarch64_musl_cc() {
  if command -v aarch64-linux-musl-gcc >/dev/null 2>&1; then
    command -v aarch64-linux-musl-gcc
    return
  fi

  if [[ -x /usr/aarch64-linux-musl/bin/musl-gcc ]]; then
    echo "/usr/aarch64-linux-musl/bin/musl-gcc"
    return
  fi

  return 1
}

rewrite_env_line() {
  local line="$1"
  local aarch64_musl_cc

  if [[ "$line" == "CC_aarch64_unknown_linux_musl=aarch64-linux-musl-gcc" ]]; then
    if aarch64_musl_cc="$(resolve_aarch64_musl_cc)"; then
      printf '%s\n' "CC_aarch64_unknown_linux_musl=$aarch64_musl_cc"
      return
    fi
    cat >&2 <<'EOF'
Missing musl cross compiler: aarch64-linux-musl-gcc
Linux builds in this repository are fully static. Install an aarch64 musl toolchain
that provides either `aarch64-linux-musl-gcc` in PATH or `/usr/aarch64-linux-musl/bin/musl-gcc`,
then rerun build_aios.
EOF
    exit 1
  fi

  if [[ "$line" == "CARGO_TARGET_AARCH64_UNKNOWN_LINUX_MUSL_LINKER=aarch64-linux-musl-gcc" ]]; then
    if aarch64_musl_cc="$(resolve_aarch64_musl_cc)"; then
      printf '%s\n' "CARGO_TARGET_AARCH64_UNKNOWN_LINUX_MUSL_LINKER=$aarch64_musl_cc"
      return
    fi
    cat >&2 <<'EOF'
Missing musl cross linker: aarch64-linux-musl-gcc
Linux builds in this repository are fully static. Install an aarch64 musl toolchain
that provides either `aarch64-linux-musl-gcc` in PATH or `/usr/aarch64-linux-musl/bin/musl-gcc`,
then rerun build_aios.
EOF
    exit 1
  fi

  if [[ "$(uname -s)" == "Darwin" ]]; then
    if [[ "$line" == "CC_x86_64_unknown_linux_musl=musl-gcc" ]] && ! command -v musl-gcc >/dev/null 2>&1; then
      if command -v x86_64-linux-musl-gcc >/dev/null 2>&1; then
        printf '%s\n' "CC_x86_64_unknown_linux_musl=$(command -v x86_64-linux-musl-gcc)"
        return
      fi
    fi

    if [[ "$line" == "CARGO_TARGET_X86_64_UNKNOWN_LINUX_MUSL_LINKER=musl-gcc" ]] && ! command -v musl-gcc >/dev/null 2>&1; then
      if command -v x86_64-linux-musl-gcc >/dev/null 2>&1; then
        printf '%s\n' "CARGO_TARGET_X86_64_UNKNOWN_LINUX_MUSL_LINKER=$(command -v x86_64-linux-musl-gcc)"
        return
      fi
    fi
  fi

  printf '%s\n' "$line"
}

build_binary() {
  local arch="$1"
  local output_path="$2"
  local cargo_target_dir="$3"
  local python_bin="$4"
  local rust_target
  local source_bin
  local -a cargo_cmd
  local -a env_cmd
  local -a env_lines
  local raw_line

  rust_target="$(resolve_rust_target "$arch")"
  env_lines=()
  while IFS= read -r raw_line; do
    if [[ "$raw_line" == RUST_TARGET=* ]]; then
      rust_target="${raw_line#RUST_TARGET=}"
    elif [[ -n "$raw_line" ]]; then
      env_lines+=("$raw_line")
    fi
  done < <(load_build_context "$python_bin" "$rust_target")

  if [[ -z "${rust_target:-}" ]]; then
    echo "Failed to resolve rust target for arch: $arch" >&2
    exit 1
  fi

  source_bin="$cargo_target_dir/$rust_target/release/opendan"

  cargo_cmd=(
    cargo
    build
    -p
    opendan
    --release
    --target
    "$rust_target"
    --target-dir
    "$cargo_target_dir"
  )

  env_cmd=(env)
  if [[ ${#env_lines[@]} -gt 0 ]]; then
    local normalized_line
    local -a normalized_env_lines=()
    for line in "${env_lines[@]}"; do
      normalized_line="$(rewrite_env_line "$line")"
      normalized_env_lines+=("$normalized_line")
    done
    env_cmd+=("${normalized_env_lines[@]}")
  fi

  log "Building opendan for $arch using target $rust_target via ${cargo_cmd[*]}"
  (
    cd "$SRC_DIR"
    "${env_cmd[@]}" "${cargo_cmd[@]}"
  )

  if [[ ! -f "$source_bin" ]]; then
    echo "Expected build output not found: $source_bin" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$output_path")"
  cp "$source_bin" "$output_path"
  chmod 755 "$output_path"
}

docker_platform_for_arch() {
  case "$1" in
    amd64)
      echo "linux/amd64"
      ;;
    aarch64)
      echo "linux/arm64"
      ;;
    *)
      echo "Unsupported arch: $1" >&2
      exit 1
      ;;
  esac
}

build_image() {
  local arch="$1"
  local context_dir="$2"
  local platform="$3"
  local dockerfile_path="$4"
  local version_arch_tag="$IMAGE_NAME:$VERSION_TAG-$arch"
  local latest_arch_tag="$IMAGE_NAME:latest-$arch"

  log "Building Docker image $version_arch_tag"

  if [[ "$PUSH" -eq 1 ]]; then
    docker buildx build \
      --platform "$platform" \
      --build-arg TARGET_ARCH="$arch" \
      --tag "$version_arch_tag" \
      --tag "$latest_arch_tag" \
      --push \
      -f "$dockerfile_path" \
      "$context_dir"
  else
    docker buildx build \
      --platform "$platform" \
      --build-arg TARGET_ARCH="$arch" \
      --tag "$version_arch_tag" \
      --tag "$latest_arch_tag" \
      --load \
      -f "$dockerfile_path" \
      "$context_dir"
  fi
}

publish_manifests() {
  log "Publishing multi-arch manifests for $IMAGE_NAME"
  docker buildx imagetools create \
    --tag "$IMAGE_NAME:$VERSION_TAG" \
    "$IMAGE_NAME:$VERSION_TAG-amd64" \
    "$IMAGE_NAME:$VERSION_TAG-aarch64"

  docker buildx imagetools create \
    --tag "$IMAGE_NAME:latest" \
    "$IMAGE_NAME:latest-amd64" \
    "$IMAGE_NAME:latest-aarch64"
}

main() {
  local tmp_root
  local python_bin

  if [[ ! -f "$PROJECT_CONFIG_PATH" ]]; then
    echo "Missing project config: $PROJECT_CONFIG_PATH" >&2
    exit 1
  fi

  resolve_version_tag
  python_bin="$(resolve_python)"

  tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/build_aios.XXXXXX")"
  trap "rm -rf '$tmp_root'" EXIT

  prepare_docker_config "$tmp_root"

  log "Version tag: $VERSION_TAG"
  log "Runtime packages: $(package_list_to_string "${RUNTIME_PACKAGES[@]}")"
  if [[ "$INSTALL_WORKSPACE_TOOLS" -eq 1 ]]; then
    log "Workspace packages: $(package_list_to_string "${WORKSPACE_PACKAGES[@]}")"
  else
    log "Workspace packages: skipped (--runtime-only)"
  fi
  if [[ ${#EXTRA_APT_PACKAGES[@]} -gt 0 ]]; then
    log "Extra apt packages: $(package_list_to_string "${EXTRA_APT_PACKAGES[@]}")"
  fi

  for arch in "${PLATFORMS[@]}"; do
    local context_dir="$tmp_root/$arch"
    local cargo_target_dir="$tmp_root/cargo-$arch"
    local dockerfile_path="$context_dir/Dockerfile"
    local platform

    platform="$(docker_platform_for_arch "$arch")"
    mkdir -p "$context_dir"

    build_binary "$arch" "$context_dir/opendan" "$cargo_target_dir" "$python_bin"
    render_dockerfile "$dockerfile_path"
    build_image "$arch" "$context_dir" "$platform" "$dockerfile_path"
  done

  if [[ "$PUSH" -eq 1 ]]; then
    publish_manifests
  fi

  log "Completed"
  if [[ "$PUSH" -eq 1 ]]; then
    log "Pushed: $IMAGE_NAME:$VERSION_TAG and $IMAGE_NAME:latest"
  else
    log "Loaded local images:"
    log "  $IMAGE_NAME:$VERSION_TAG-amd64"
    log "  $IMAGE_NAME:latest-amd64"
    log "  $IMAGE_NAME:$VERSION_TAG-aarch64"
    log "  $IMAGE_NAME:latest-aarch64"
  fi
}

main
