#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SRC_DIR="$ROOT_DIR/src"
PROJECT_CONFIG_PATH="$SRC_DIR/bucky_project.yaml"
DEFAULT_IMAGE_NAME="paios/aios"
DEVENV_PATH="$ROOT_DIR/devenv.json"
IMAGE_NAME="${IMAGE_NAME:-}"
VERSION_FILE="$SRC_DIR/VERSION"
VERSION_TAG="${VERSION_TAG:-}"
SUPPORTED_ARCHES=("amd64" "aarch64")
# Core runtime + predefined Worker Image CLI tool set (see container
# requirements §6.3). No compile toolchain — Crafter is deferred.
RUNTIME_PACKAGES=(
  "bash" "ca-certificates" "curl" "git" "jq" "locales" "rsync"
  "tmux" "tree" "unzip" "xz-utils"
  "python3" "python3-venv"
  "nodejs" "npm"
  "ffmpeg" "imagemagick" "poppler-utils" "pandoc" "tesseract-ocr"
)
# Legacy flag kept for CLI compat; the Worker Image always ships the tool set.
WORKSPACE_PACKAGES=()
EXTRA_APT_PACKAGES=()
SELECTED_ARCHES=()
PUSH=0
INSTALL_WORKSPACE_TOOLS=1
ENTRYPOINT_SOURCE="$ROOT_DIR/publish/aios/entrypoint.sh"
REUSE_CARGO_TARGET=0
CARGO_TARGET_DIR_OVERRIDE="${AIOS_CARGO_TARGET_DIR:-}"

usage() {
  cat <<'EOF'
Usage: ./build_aios [--push] [--image <name>] [--tag <tag>] [--runtime-only] [--arch <arch>] [--apt-package <name>] [--reuse-cargo-target] [--cargo-target-dir <dir>]

Builds the OpenDAN binary with cargo for:
  - amd64   -> x86_64-unknown-linux-musl
  - aarch64 -> aarch64-unknown-linux-musl

Then packages each binary into an Ubuntu-based Docker image:
  - <image>:<tag>-amd64
  - <image>:latest-amd64
  - <image>:<tag>-aarch64
  - <image>:latest-aarch64

Options:
  --push          Push arch-specific images and create multi-arch manifests
  --image <name>  Override image name, default: devenv.json["aios"] or paios/aios
  --tag <tag>     Override version tag, default: src/VERSION
  --runtime-only  Install only required runtime dependencies in the image
  --arch <arch>   Build only one architecture (amd64|aarch64); can be repeated
  --apt-package   Add an extra apt package to the image; can be repeated
  --reuse-cargo-target
                  Reuse Cargo artifacts from a stable /tmp cache across runs (development only)
  --cargo-target-dir <dir>
                  Reuse a specific Cargo target dir; relative paths are resolved from repo root
  -h, --help      Show this help
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --push)
      PUSH=1
      shift
      ;;
    --image)
      IMAGE_NAME="$2"
      shift 2
      ;;
    --tag)
      VERSION_TAG="$2"
      shift 2
      ;;
    --runtime-only)
      INSTALL_WORKSPACE_TOOLS=0
      shift
      ;;
    --arch)
      SELECTED_ARCHES+=("$2")
      shift 2
      ;;
    --apt-package)
      EXTRA_APT_PACKAGES+=("$2")
      shift 2
      ;;
    --reuse-cargo-target)
      REUSE_CARGO_TARGET=1
      shift
      ;;
    --cargo-target-dir)
      CARGO_TARGET_DIR_OVERRIDE="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

log() {
  printf '[build_aios] %s\n' "$*"
}

default_reused_cargo_target_dir() {
  local tmp_base="${TMPDIR:-/tmp}"
  local repo_name
  local repo_key
  local cache_owner

  repo_name="$(basename "$ROOT_DIR" | tr -c 'A-Za-z0-9._-' '_')"
  repo_key="$(printf '%s' "$ROOT_DIR" | cksum | awk '{print $1}')"
  cache_owner="${USER:-$(id -un 2>/dev/null || id -u)}"

  printf '%s\n' "$tmp_base/build_aios-cargo-$cache_owner-$repo_name-$repo_key"
}

resolve_cargo_target_dir() {
  local tmp_root="$1"

  if [[ -n "$CARGO_TARGET_DIR_OVERRIDE" ]]; then
    if [[ "$CARGO_TARGET_DIR_OVERRIDE" == /* ]]; then
      printf '%s\n' "$CARGO_TARGET_DIR_OVERRIDE"
    else
      printf '%s\n' "$ROOT_DIR/$CARGO_TARGET_DIR_OVERRIDE"
    fi
    return
  fi

  if [[ "$REUSE_CARGO_TARGET" -eq 1 ]]; then
    default_reused_cargo_target_dir
    return
  fi

  printf '%s\n' "$tmp_root/cargo"
}

prepare_docker_config() {
  local workspace_tmp_root="$1"
  local docker_config_dir="${DOCKER_CONFIG:-$HOME/.docker}"
  local docker_config_path="$docker_config_dir/config.json"
  local sanitized_dir="$workspace_tmp_root/docker-config"
  local sanitized_config_path="$sanitized_dir/config.json"
  local python_bin
  local sanitize_result

  if [[ "$(uname -s)" != "Linux" ]]; then
    return
  fi

  if [[ ! -f "$docker_config_path" ]]; then
    return
  fi

  python_bin="$(resolve_python)"
  sanitize_result="$(
    "$python_bin" - "$docker_config_path" "$sanitized_config_path" <<'PY'
import json
import os
import shutil
import sys

config_path = sys.argv[1]
output_path = sys.argv[2]

with open(config_path, "r", encoding="utf-8") as fh:
    config = json.load(fh)

removed = []

def helper_binary(helper):
    return f"docker-credential-{helper}"

def helper_missing(helper):
    return shutil.which(helper_binary(helper)) is None

creds_store = config.get("credsStore")
if isinstance(creds_store, str) and helper_missing(creds_store):
    removed.append(f"credsStore={creds_store}")
    config.pop("credsStore", None)

cred_helpers = config.get("credHelpers")
if isinstance(cred_helpers, dict):
    sanitized_helpers = {}
    for registry, helper in cred_helpers.items():
        if isinstance(helper, str) and helper_missing(helper):
            removed.append(f"credHelpers[{registry}]={helper}")
            continue
        sanitized_helpers[registry] = helper
    if sanitized_helpers:
        config["credHelpers"] = sanitized_helpers
    else:
        config.pop("credHelpers", None)

if not removed:
    print("UNCHANGED")
    raise SystemExit(0)

os.makedirs(os.path.dirname(output_path), exist_ok=True)
with open(output_path, "w", encoding="utf-8") as fh:
    json.dump(config, fh, indent=2)
    fh.write("\n")

print("SANITIZED")
for item in removed:
    print(item)
PY
  )"

  if [[ "$sanitize_result" == UNCHANGED* ]]; then
    return
  fi

  export DOCKER_CONFIG="$sanitized_dir"
  log "Detected missing Docker credential helper(s); using sanitized DOCKER_CONFIG at $DOCKER_CONFIG"
  while IFS= read -r line; do
    [[ "$line" == "SANITIZED" || -z "$line" ]] && continue
    log "  removed $line"
  done <<< "$sanitize_result"
}

resolve_version_tag() {
  if [[ -n "$VERSION_TAG" ]]; then
    return
  fi

  if [[ ! -f "$VERSION_FILE" ]]; then
    echo "Missing version file: $VERSION_FILE" >&2
    exit 1
  fi

  VERSION_TAG="$(tr -d '[:space:]' < "$VERSION_FILE")"

  if [[ -z "$VERSION_TAG" ]]; then
    echo "Version file is empty: $VERSION_FILE" >&2
    exit 1
  fi
}

validate_arch() {
  local arch="$1"

  case "$arch" in
    amd64|aarch64)
      ;;
    *)
      echo "Unsupported arch: $arch" >&2
      exit 1
      ;;
  esac
}

resolve_selected_arches() {
  local -a resolved=()

  if [[ ${#SELECTED_ARCHES[@]} -eq 0 ]]; then
    resolved=("${SUPPORTED_ARCHES[@]}")
  else
    local arch
    for arch in "${SELECTED_ARCHES[@]}"; do
      validate_arch "$arch"
      if [[ ! " ${resolved[*]} " =~ " ${arch} " ]]; then
        resolved+=("$arch")
      fi
    done
  fi

  printf '%s\n' "${resolved[@]}"
}

package_list_to_string() {
  local IFS=' '
  printf '%s' "$*"
}

render_dockerfile() {
  local output_path="$1"
  local -a apt_packages=("${RUNTIME_PACKAGES[@]}")

  if [[ ${#EXTRA_APT_PACKAGES[@]} -gt 0 ]]; then
    apt_packages+=("${EXTRA_APT_PACKAGES[@]}")
  fi

  {
    cat <<'EOF'
FROM ubuntu:24.04

ARG TARGET_ARCH

LABEL org.opencontainers.image.title="paios/aios (BuckyOS Worker Image)" \
EOF
    printf '      org.opencontainers.image.description="Unified worker runtime for %s" \\\n' "$IMAGE_NAME"
    cat <<'EOF'
      org.opencontainers.image.vendor="BuckyOS DAO"

ENV DEBIAN_FRONTEND=noninteractive

# Runtime + predefined worker CLI tools (see container spec §6.3).
RUN apt-get update && apt-get install -y --no-install-recommends \
EOF

    for package in "${apt_packages[@]}"; do
      printf '    %s \\\n' "$package"
    done

    cat <<'EOF'
    && rm -rf /var/lib/apt/lists/* \
    && locale-gen en_US.UTF-8

ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

# uv — managed Python + dependency installer used by Script apps.
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"
RUN uv python install 3.12

# Deno — TypeScript runtime used by Script apps and Worker-layer Agents.
RUN curl -fsSL https://deno.land/install.sh | DENO_INSTALL=/usr/local sh

ENV BUCKYOS_ROOT=/opt/buckyos
WORKDIR /opt/buckyos

# ExtTool Volume mount point — kept empty in the Worker image. The real
# payload (FreeCAD, pre-warmed uv/deno caches, tool packages) ships in the
# separate paios/exttool image and lands in the buckyos-exttool named
# volume, which node_daemon mounts here ro at run time (§6.3 of paios容器需求.md).
RUN mkdir -p \
    /opt/buckyos/bin/opendan \
    /opt/buckyos/data \
    /opt/buckyos/logs \
    /opt/buckyos/storage \
    /opt/buckyos/tools/store \
    /opt/buckyos/tools/bin \
    /mnt/buckyos/pkg

COPY opendan /opt/buckyos/bin/opendan/opendan
COPY agent_tool /opt/buckyos/bin/opendan/agent_tool
RUN chmod 755 /opt/buckyos/bin/opendan/opendan /opt/buckyos/bin/opendan/agent_tool

# Unified entrypoint: instance-volume bootstrap + file-level upstream sync +
# agent/script/custom dispatch.
COPY entrypoint.sh /opt/buckyos/entrypoint.sh
RUN chmod 755 /opt/buckyos/entrypoint.sh

ENV AIOS_TARGET_ARCH="${TARGET_ARCH}" \
    BUCKYOS_INSTANCE_VOLUME=/opt/buckyos/instance \
    BUCKYOS_PKG_SOURCE_DIR=/mnt/buckyos/pkg \
    BUCKYOS_EXTTOOL_DIR=/opt/buckyos/tools \
    DENO_DIR=/opt/buckyos/instance/deno-cache \
    UV_CACHE_DIR=/opt/buckyos/instance/uv-cache \
    NPM_CONFIG_CACHE=/opt/buckyos/instance/npm-cache \
    PIP_CACHE_DIR=/opt/buckyos/instance/pip-cache \
    PATH="/opt/buckyos/tools/bin:${PATH}"

EXPOSE 3180

ENTRYPOINT ["/opt/buckyos/entrypoint.sh"]
EOF
  } > "$output_path"
}

resolve_python() {
  if [[ -x "$ROOT_DIR/venv/bin/python" ]]; then
    echo "$ROOT_DIR/venv/bin/python"
    return
  fi

  if [[ -x "$ROOT_DIR/venv/bin/python3" ]]; then
    echo "$ROOT_DIR/venv/bin/python3"
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    command -v python3
    return
  fi

  echo "python3 not found" >&2
  exit 1
}

resolve_default_image_name() {
  local python_bin
  local resolved_image

  if [[ -n "$IMAGE_NAME" ]]; then
    return
  fi

  if [[ ! -f "$DEVENV_PATH" ]]; then
    IMAGE_NAME="$DEFAULT_IMAGE_NAME"
    return
  fi

  python_bin="$(resolve_python)"
  resolved_image="$(
    "$python_bin" - "$DEVENV_PATH" "$DEFAULT_IMAGE_NAME" <<'PY'
import json
import sys

config_path = sys.argv[1]
default_image = sys.argv[2]

try:
    with open(config_path, "r", encoding="utf-8") as fh:
        config = json.load(fh)
except Exception:
    print(default_image)
    raise SystemExit(0)

image = config.get("aios")
if isinstance(image, str) and image.strip():
    print(image.strip())
else:
    print(default_image)
PY
  )"

  IMAGE_NAME="${resolved_image:-$DEFAULT_IMAGE_NAME}"
}

load_build_context() {
  local python_bin="$1"
  local rust_target="$2"
  local -a python_cmd
  local musl_cc=""
  local musl_tool_bin_dir=""
  local -a python_env_cmd=(env)

  if "$python_bin" - <<'PY' >/dev/null 2>&1
import importlib.util
import sys

sys.exit(0 if importlib.util.find_spec("buckyos_devkit") else 1)
PY
  then
    python_cmd=("$python_bin")
  elif command -v uv >/dev/null 2>&1; then
    if (
      cd "$SRC_DIR"
      uv run python - <<'PY' >/dev/null 2>&1
import importlib.util
import sys

sys.exit(0 if importlib.util.find_spec("buckyos_devkit") else 1)
PY
    ); then
      python_cmd=(uv run python)
    fi
  fi

  if [[ ${#python_cmd[@]} -eq 0 ]]; then
    cat >&2 <<EOF
Failed to load build context for $rust_target.
Neither $python_bin nor \`uv run python\` can import \`buckyos_devkit\`.
Install the build dependencies or run this script from a repository environment
where \`uv run python -c 'import buckyos_devkit'\` succeeds.
EOF
    return 1
  fi

  case "$rust_target" in
    x86_64-unknown-linux-musl)
      if musl_cc="$(resolve_x86_64_musl_cc)"; then
        musl_tool_bin_dir="$(dirname "$musl_cc")"
      fi
      ;;
    aarch64-unknown-linux-musl)
      if musl_cc="$(resolve_aarch64_musl_cc)"; then
        musl_tool_bin_dir="$(dirname "$musl_cc")"
      fi
      ;;
  esac

  if [[ -n "$musl_tool_bin_dir" ]]; then
    python_env_cmd+=("PATH=$musl_tool_bin_dir:$PATH")
  fi

  "${python_env_cmd[@]}" "${python_cmd[@]}" - "$PROJECT_CONFIG_PATH" "$rust_target" <<'PY'
import contextlib
import io
import sys

config_path = sys.argv[1]
target = sys.argv[2]

with contextlib.redirect_stdout(io.StringIO()):
    from buckyos_devkit.build_rust import get_cross_compile_env_vars_by_target, get_env_vars_by_target
    from buckyos_devkit.project import BuckyProject

    project = BuckyProject.from_file(config_path)

    env = {}
    env.update(project.rust_env)
    env.update(get_env_vars_by_target(target))

    cross_env = get_cross_compile_env_vars_by_target(target)
    if cross_env:
        env.update(cross_env)

print(f"RUST_TARGET={target}")
for key, value in env.items():
    print(f"{key}={value}")
PY
}

resolve_rust_target() {
  local arch="$1"

  case "$arch" in
    amd64)
      echo "x86_64-unknown-linux-musl"
      ;;
    aarch64)
      echo "aarch64-unknown-linux-musl"
      ;;
    *)
      echo "Unsupported arch: $arch" >&2
      exit 1
      ;;
  esac
}

resolve_x86_64_musl_cc() {
  if command -v x86_64-linux-musl-gcc >/dev/null 2>&1; then
    command -v x86_64-linux-musl-gcc
    return
  fi

  if command -v musl-gcc >/dev/null 2>&1; then
    command -v musl-gcc
    return
  fi

  return 1
}

resolve_x86_64_musl_cxx() {
  if command -v x86_64-linux-musl-g++ >/dev/null 2>&1; then
    command -v x86_64-linux-musl-g++
    return
  fi

  if command -v musl-g++ >/dev/null 2>&1; then
    command -v musl-g++
    return
  fi

  return 1
}

resolve_aarch64_musl_cc() {
  if command -v aarch64-linux-musl-gcc >/dev/null 2>&1; then
    command -v aarch64-linux-musl-gcc
    return
  fi

  if [[ -x /usr/aarch64-linux-musl/bin/musl-gcc ]]; then
    echo "/usr/aarch64-linux-musl/bin/musl-gcc"
    return
  fi

  if [[ -x /opt/musl-cross/bin/aarch64-linux-musl-gcc ]]; then
    echo "/opt/musl-cross/bin/aarch64-linux-musl-gcc"
    return
  fi

  return 1
}

resolve_aarch64_musl_tool() {
  local tool_bin_dir="$1"
  shift
  local candidate

  for candidate in "$@"; do
    if command -v "$candidate" >/dev/null 2>&1; then
      command -v "$candidate"
      return
    fi

    if [[ -n "$tool_bin_dir" && -x "$tool_bin_dir/$candidate" ]]; then
      echo "$tool_bin_dir/$candidate"
      return
    fi
  done

  return 1
}

append_x86_64_musl_env_lines() {
  local -n env_lines_ref="$1"
  local x86_64_musl_cc
  local x86_64_musl_cxx
  local tool_bin_dir
  local x86_64_musl_ar
  local x86_64_musl_ranlib

  if ! x86_64_musl_cc="$(resolve_x86_64_musl_cc)"; then
    cat >&2 <<'EOF'
Missing musl compiler for x86_64-linux-musl.
Linux builds in this repository are fully static. Install a musl toolchain that provides:
  - `x86_64-linux-musl-gcc` in PATH
  - or `musl-gcc` in PATH
then rerun build_aios.
EOF
    exit 1
  fi

  if ! "$x86_64_musl_cc" -dumpmachine >/dev/null 2>&1; then
    cat >&2 <<EOF
Resolved musl compiler is not runnable: $x86_64_musl_cc
Ensure the full x86_64 musl toolchain is installed, then rerun build_aios.
EOF
    exit 1
  fi

  tool_bin_dir="$(dirname "$x86_64_musl_cc")"
  env_lines_ref+=("PATH=$tool_bin_dir:$PATH")
  env_lines_ref+=("CC_x86_64_unknown_linux_musl=$x86_64_musl_cc")
  env_lines_ref+=("CARGO_TARGET_X86_64_UNKNOWN_LINUX_MUSL_LINKER=$x86_64_musl_cc")

  if x86_64_musl_ar="$(resolve_aarch64_musl_tool "$tool_bin_dir" \
    x86_64-linux-musl-ar x86_64-linux-musl-gcc-ar ar)"; then
    env_lines_ref+=("AR_x86_64_unknown_linux_musl=$x86_64_musl_ar")
  fi

  if x86_64_musl_ranlib="$(resolve_aarch64_musl_tool "$tool_bin_dir" \
    x86_64-linux-musl-ranlib x86_64-linux-musl-gcc-ranlib ranlib)"; then
    env_lines_ref+=("RANLIB_x86_64_unknown_linux_musl=$x86_64_musl_ranlib")
  fi

  if x86_64_musl_cxx="$(resolve_x86_64_musl_cxx)"; then
    env_lines_ref+=("CXX_x86_64_unknown_linux_musl=$x86_64_musl_cxx")
  else
    log "x86_64 musl C++ compiler not found; crates with C++ deps (for example rocksdb) require x86_64-linux-musl-g++ or musl-g++"
  fi
}

append_aarch64_musl_env_lines() {
  local -n env_lines_ref="$1"
  local aarch64_musl_cc
  local tool_bin_dir
  local aarch64_musl_ar
  local aarch64_musl_ranlib

  if ! aarch64_musl_cc="$(resolve_aarch64_musl_cc)"; then
    cat >&2 <<'EOF'
Missing musl cross compiler: aarch64-linux-musl-gcc
Linux builds in this repository are fully static. Install an aarch64 musl toolchain
that provides one of:
  - `aarch64-linux-musl-gcc` in PATH
  - `/usr/aarch64-linux-musl/bin/musl-gcc`
  - `/opt/musl-cross/bin/aarch64-linux-musl-gcc`
then rerun build_aios.
EOF
    exit 1
  fi

  if ! "$aarch64_musl_cc" -dumpmachine >/dev/null 2>&1; then
    cat >&2 <<EOF
Resolved musl cross compiler is not runnable: $aarch64_musl_cc
This usually means the toolchain is installed in a non-standard location but its
support files are incomplete or unavailable. Ensure the full aarch64 musl toolchain
is installed, then rerun build_aios.
EOF
    exit 1
  fi

  tool_bin_dir="$(dirname "$aarch64_musl_cc")"
  env_lines_ref+=("PATH=$tool_bin_dir:$PATH")

  if aarch64_musl_ar="$(resolve_aarch64_musl_tool "$tool_bin_dir" \
    aarch64-linux-musl-ar aarch64-linux-musl-gcc-ar ar)"; then
    env_lines_ref+=("AR_aarch64_unknown_linux_musl=$aarch64_musl_ar")
  fi

  if aarch64_musl_ranlib="$(resolve_aarch64_musl_tool "$tool_bin_dir" \
    aarch64-linux-musl-ranlib aarch64-linux-musl-gcc-ranlib ranlib)"; then
    env_lines_ref+=("RANLIB_aarch64_unknown_linux_musl=$aarch64_musl_ranlib")
  fi
}

rewrite_env_line() {
  local line="$1"
  local aarch64_musl_cc

  if [[ "$line" == "CC_aarch64_unknown_linux_musl=aarch64-linux-musl-gcc" ]]; then
    if aarch64_musl_cc="$(resolve_aarch64_musl_cc)"; then
      printf '%s\n' "CC_aarch64_unknown_linux_musl=$aarch64_musl_cc"
      return
    fi
    cat >&2 <<'EOF'
Missing musl cross compiler: aarch64-linux-musl-gcc
Linux builds in this repository are fully static. Install an aarch64 musl toolchain
that provides one of:
  - `aarch64-linux-musl-gcc` in PATH
  - `/usr/aarch64-linux-musl/bin/musl-gcc`
  - `/opt/musl-cross/bin/aarch64-linux-musl-gcc`
then rerun build_aios.
EOF
    exit 1
  fi

  if [[ "$line" == "CARGO_TARGET_AARCH64_UNKNOWN_LINUX_MUSL_LINKER=aarch64-linux-musl-gcc" ]]; then
    if aarch64_musl_cc="$(resolve_aarch64_musl_cc)"; then
      printf '%s\n' "CARGO_TARGET_AARCH64_UNKNOWN_LINUX_MUSL_LINKER=$aarch64_musl_cc"
      return
    fi
    cat >&2 <<'EOF'
Missing musl cross linker: aarch64-linux-musl-gcc
Linux builds in this repository are fully static. Install an aarch64 musl toolchain
that provides one of:
  - `aarch64-linux-musl-gcc` in PATH
  - `/usr/aarch64-linux-musl/bin/musl-gcc`
  - `/opt/musl-cross/bin/aarch64-linux-musl-gcc`
then rerun build_aios.
EOF
    exit 1
  fi

  if [[ "$(uname -s)" == "Darwin" ]]; then
    if [[ "$line" == "CC_x86_64_unknown_linux_musl=musl-gcc" ]] && ! command -v musl-gcc >/dev/null 2>&1; then
      if command -v x86_64-linux-musl-gcc >/dev/null 2>&1; then
        printf '%s\n' "CC_x86_64_unknown_linux_musl=$(command -v x86_64-linux-musl-gcc)"
        return
      fi
    fi

    if [[ "$line" == "CARGO_TARGET_X86_64_UNKNOWN_LINUX_MUSL_LINKER=musl-gcc" ]] && ! command -v musl-gcc >/dev/null 2>&1; then
      if command -v x86_64-linux-musl-gcc >/dev/null 2>&1; then
        printf '%s\n' "CARGO_TARGET_X86_64_UNKNOWN_LINUX_MUSL_LINKER=$(command -v x86_64-linux-musl-gcc)"
        return
      fi
    fi
  fi

  printf '%s\n' "$line"
}

build_runtime_binaries() {
  local arch="$1"
  local context_dir="$2"
  local cargo_target_dir="$3"
  local python_bin="$4"
  local rust_target
  local source_opendan
  local source_agent_tool
  local -a cargo_cmd
  local -a env_cmd
  local -a env_lines
  local build_context_output
  local raw_line

  rust_target="$(resolve_rust_target "$arch")"
  env_lines=()
  build_context_output="$(load_build_context "$python_bin" "$rust_target")"
  while IFS= read -r raw_line; do
    if [[ "$raw_line" == RUST_TARGET=* ]]; then
      rust_target="${raw_line#RUST_TARGET=}"
    elif [[ -n "$raw_line" ]]; then
      env_lines+=("$raw_line")
    fi
  done <<< "$build_context_output"

  if [[ -z "${rust_target:-}" ]]; then
    echo "Failed to resolve rust target for arch: $arch" >&2
    exit 1
  fi

  source_opendan="$cargo_target_dir/$rust_target/release/opendan"
  source_agent_tool="$cargo_target_dir/$rust_target/release/agent_tool"

  cargo_cmd=(
    cargo
    build
    -p
    opendan
    -p
    agent_tool
    --release
    --target
    "$rust_target"
    --target-dir
    "$cargo_target_dir"
  )

  env_cmd=(env)
  if [[ ${#env_lines[@]} -gt 0 ]]; then
    local normalized_line
    local -a normalized_env_lines=()
    for line in "${env_lines[@]}"; do
      normalized_line="$(rewrite_env_line "$line")"
      normalized_env_lines+=("$normalized_line")
    done
    if [[ "$rust_target" == "x86_64-unknown-linux-musl" ]]; then
      append_x86_64_musl_env_lines normalized_env_lines
    elif [[ "$rust_target" == "aarch64-unknown-linux-musl" ]]; then
      append_aarch64_musl_env_lines normalized_env_lines
    fi
    env_cmd+=("${normalized_env_lines[@]}")
  fi

  log "Building opendan and agent_tool for $arch using target $rust_target via ${cargo_cmd[*]}"
  (
    cd "$SRC_DIR"
    "${env_cmd[@]}" "${cargo_cmd[@]}"
  )

  if [[ ! -f "$source_opendan" ]]; then
    echo "Expected build output not found: $source_opendan" >&2
    exit 1
  fi

  if [[ ! -f "$source_agent_tool" ]]; then
    echo "Expected build output not found: $source_agent_tool" >&2
    exit 1
  fi

  mkdir -p "$context_dir"
  cp "$source_opendan" "$context_dir/opendan"
  cp "$source_agent_tool" "$context_dir/agent_tool"
  chmod 755 "$context_dir/opendan" "$context_dir/agent_tool"

  if [[ ! -f "$ENTRYPOINT_SOURCE" ]]; then
    echo "Missing paios/aios entrypoint at $ENTRYPOINT_SOURCE" >&2
    exit 1
  fi
  cp "$ENTRYPOINT_SOURCE" "$context_dir/entrypoint.sh"
  chmod 755 "$context_dir/entrypoint.sh"
}

docker_platform_for_arch() {
  case "$1" in
    amd64)
      echo "linux/amd64"
      ;;
    aarch64)
      echo "linux/arm64"
      ;;
    *)
      echo "Unsupported arch: $1" >&2
      exit 1
      ;;
  esac
}

ensure_buildx_support() {
  local -a arches=("$@")
  local builder_info
  local platforms
  local missing=()
  local arch
  if ! builder_info="$(docker buildx inspect 2>/dev/null)"; then
    cat >&2 <<'EOF'
docker buildx inspect failed.
Ensure Docker Buildx is available and the current builder is healthy before running build_aios.
EOF
    exit 1
  fi

  platforms="$(printf '%s\n' "$builder_info" | sed -n 's/^Platforms:[[:space:]]*//p' | head -n1 | tr -d ' ')"
  if [[ -z "$platforms" ]]; then
    cat >&2 <<'EOF'
Failed to detect platforms supported by the active docker buildx builder.
Run `docker buildx inspect --bootstrap` and verify the current builder is usable.
EOF
    exit 1
  fi

  for arch in "${arches[@]}"; do
    if [[ ",$platforms," != *",$(docker_platform_for_arch "$arch"),"* ]]; then
      missing+=("$arch")
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    cat >&2 <<EOF
Active docker buildx builder does not support the requested architecture(s): ${missing[*]}
Builder platforms: $platforms

Fix the Docker/buildx environment first, then rerun build_aios. Typical checks:
  docker buildx inspect --bootstrap
  docker run --privileged --rm tonistiigi/binfmt --install arm64

If you use Docker Desktop, also make sure the Desktop builder/context is healthy.
EOF
    exit 1
  fi

  log "Using current buildx builder platforms: $platforms"
}

build_image() {
  local arch="$1"
  local context_dir="$2"
  local platform="$3"
  local dockerfile_path="$4"
  local version_arch_tag="$IMAGE_NAME:$VERSION_TAG-$arch"
  local latest_arch_tag="$IMAGE_NAME:latest-$arch"

  log "Building Docker image $version_arch_tag"

  if [[ "$PUSH" -eq 1 ]]; then
    docker buildx build \
      --platform "$platform" \
      --build-arg TARGET_ARCH="$arch" \
      --tag "$version_arch_tag" \
      --tag "$latest_arch_tag" \
      --push \
      -f "$dockerfile_path" \
      "$context_dir"
  else
    docker buildx build \
      --platform "$platform" \
      --build-arg TARGET_ARCH="$arch" \
      --tag "$version_arch_tag" \
      --tag "$latest_arch_tag" \
      --load \
      -f "$dockerfile_path" \
      "$context_dir"
  fi
}

publish_manifests() {
  log "Publishing multi-arch manifests for $IMAGE_NAME"
  docker buildx imagetools create \
    --tag "$IMAGE_NAME:$VERSION_TAG" \
    "$IMAGE_NAME:$VERSION_TAG-amd64" \
    "$IMAGE_NAME:$VERSION_TAG-aarch64"

  docker buildx imagetools create \
    --tag "$IMAGE_NAME:latest" \
    "$IMAGE_NAME:latest-amd64" \
    "$IMAGE_NAME:latest-aarch64"
}

main() {
  local tmp_root
  local python_bin
  local cargo_target_dir
  local cargo_target_mode
  local -a target_arches

  if [[ ! -f "$PROJECT_CONFIG_PATH" ]]; then
    echo "Missing project config: $PROJECT_CONFIG_PATH" >&2
    exit 1
  fi

  resolve_default_image_name
  resolve_version_tag
  python_bin="$(resolve_python)"
  mapfile -t target_arches < <(resolve_selected_arches)

  tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/build_aios.XXXXXX")"
  trap "rm -rf '$tmp_root'" EXIT

  cargo_target_dir="$(resolve_cargo_target_dir "$tmp_root")"
  mkdir -p "$cargo_target_dir"

  if [[ -n "$CARGO_TARGET_DIR_OVERRIDE" ]]; then
    cargo_target_mode="persistent (explicit)"
  elif [[ "$REUSE_CARGO_TARGET" -eq 1 ]]; then
    cargo_target_mode="persistent (--reuse-cargo-target)"
  else
    cargo_target_mode="ephemeral"
  fi

  prepare_docker_config "$tmp_root"
  ensure_buildx_support "${target_arches[@]}"

  log "Version tag: $VERSION_TAG"
  log "Image repo: $IMAGE_NAME"
  log "Target arches: $(package_list_to_string "${target_arches[@]}")"
  log "Cargo target dir: $cargo_target_dir ($cargo_target_mode)"
  log "Runtime packages: $(package_list_to_string "${RUNTIME_PACKAGES[@]}")"
  if [[ "$INSTALL_WORKSPACE_TOOLS" -eq 1 ]]; then
    log "Workspace packages: $(package_list_to_string "${WORKSPACE_PACKAGES[@]}")"
  else
    log "Workspace packages: skipped (--runtime-only)"
  fi
  if [[ ${#EXTRA_APT_PACKAGES[@]} -gt 0 ]]; then
    log "Extra apt packages: $(package_list_to_string "${EXTRA_APT_PACKAGES[@]}")"
  fi

  for arch in "${target_arches[@]}"; do
    local context_dir="$tmp_root/$arch"
    local dockerfile_path="$context_dir/Dockerfile"
    local platform

    platform="$(docker_platform_for_arch "$arch")"
    mkdir -p "$context_dir"

    build_runtime_binaries "$arch" "$context_dir" "$cargo_target_dir" "$python_bin"
    render_dockerfile "$dockerfile_path"
    build_image "$arch" "$context_dir" "$platform" "$dockerfile_path"
  done

  if [[ "$PUSH" -eq 1 ]]; then
    publish_manifests
  fi

  log "Completed"
  if [[ "$PUSH" -eq 1 ]]; then
    log "Pushed: $IMAGE_NAME:$VERSION_TAG and $IMAGE_NAME:latest"
  else
    log "Loaded local images:"
    log "  $IMAGE_NAME:$VERSION_TAG-amd64"
    log "  $IMAGE_NAME:latest-amd64"
    log "  $IMAGE_NAME:$VERSION_TAG-aarch64"
    log "  $IMAGE_NAME:latest-aarch64"
  fi
}

main
