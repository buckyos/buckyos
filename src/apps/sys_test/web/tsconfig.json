{
  "include": ["src", "**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "ESNext",
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "useUnknownInCatchVariables": false,
    "baseUrl": ".",
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  }
}
