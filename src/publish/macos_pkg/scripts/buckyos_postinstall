#!/bin/zsh
set -e
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
BUCKYOS_ROOT="${BUCKYOS_ROOT:-/opt/buckyos}"
DEFAULTS_DIR="$BUCKYOS_ROOT/.buckyos_installer_defaults"
REAL_BUCKYOS_ROOT="$(cd "$BUCKYOS_ROOT" 2>/dev/null && pwd -P || printf '%s\n' "$BUCKYOS_ROOT")"
# Run node_daemon as a system LaunchDaemon (root) so it can bind privileged ports (80/443).
PLIST="/Library/LaunchDaemons/buckyos.service.plist"
POSTINSTALL_LOG="/private/tmp/buckyos-postinstall.log"

mkdir -p "$(dirname "$POSTINSTALL_LOG")"
touch "$POSTINSTALL_LOG" >/dev/null 2>&1 || true
exec > >(tee -a "$POSTINSTALL_LOG") 2>&1

run_with_timeout() {
  local seconds="$1"
  shift
  /usr/bin/perl -e '$t=shift; alarm $t; exec @ARGV' "$seconds" "$@"
}

start_buckyos_service() {
  echo "[buckyos] postinstall: starting LaunchDaemon"
  if [ ! -x "${REAL_BUCKYOS_ROOT}/bin/node-daemon/node_daemon" ]; then
    echo "[buckyos] postinstall: missing or non-executable node_daemon at ${REAL_BUCKYOS_ROOT}/bin/node-daemon/node_daemon" >&2
    return 1
  fi
  /usr/bin/plutil -lint "$PLIST"
  run_with_timeout 10 launchctl enable "system/buckyos.service" >/dev/null 2>&1 || true
  run_with_timeout 10 launchctl bootout system "$PLIST" >/dev/null 2>&1 || true
  if ! run_with_timeout 10 launchctl bootstrap system "$PLIST"; then
    echo "[buckyos] postinstall: launchctl bootstrap failed for $PLIST" >&2
    launchctl print system/buckyos.service >&2 || true
    return 1
  fi
  if ! run_with_timeout 10 launchctl kickstart -k "system/buckyos.service"; then
    echo "[buckyos] postinstall: launchctl kickstart failed, continuing to wait for RunAtLoad." >&2
    launchctl print system/buckyos.service >&2 || true
  fi
}

wait_for_node_daemon() {
  local attempt=1
  while [ "$attempt" -le 15 ]; do
    if /usr/bin/pgrep -f "${BUCKYOS_ROOT}/bin/node-daemon/node_daemon --enable_active" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
    attempt=$((attempt + 1))
  done
  return 1
}

mkdir -p "/Library/LaunchDaemons"
mkdir -p "${REAL_BUCKYOS_ROOT}/logs/node_daemon" || true
chown -R root:wheel "${REAL_BUCKYOS_ROOT}/logs" >/dev/null 2>&1 || true
cat > "$PLIST" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>buckyos.service</string>
    <key>ProgramArguments</key>
    <array>
        <string>${REAL_BUCKYOS_ROOT}/bin/node-daemon/node_daemon</string>
        <string>--enable_active</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${REAL_BUCKYOS_ROOT}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>BUCKYOS_ROOT</key>
        <string>${REAL_BUCKYOS_ROOT}</string>
        <key>HOME</key>
        <string>/var/root</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>RUST_BACKTRACE</key>
        <string>1</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/var/log/buckyos.service.out.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/buckyos.service.err.log</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>AbandonProcessGroup</key>
    <true/>
</dict>
</plist>
EOF
# /Library/LaunchDaemons plists should not be writable by non-root users.
chown root:wheel "$PLIST" || true
chmod 644 "$PLIST"
echo "[buckyos] postinstall: install data_paths if missing (overwrite install semantics)"

# Keep ${BUCKYOS_ROOT}/home stable for legacy paths, but store actual data under
# the interactive user's home directory: ~/my_pi.
# IMPORTANT: This function definition must be placed BEFORE the auto-generated
# data_paths block so that regeneration won't overwrite it.
setup_user_home_symlink() {
  local console_user home_dir user_group user_home_target

  console_user="$(/usr/bin/stat -f%Su /dev/console 2>/dev/null || true)"
  if [ -z "$console_user" ] || [ "$console_user" = "root" ] || [ "$console_user" = "loginwindow" ]; then
    return 0
  fi

  home_dir="$(/usr/bin/dscl . -read /Users/"$console_user" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}')"
  if [ -z "$home_dir" ] || [ ! -d "$home_dir" ]; then
    return 0
  fi

  user_group="$(/usr/bin/id -gn "$console_user" 2>/dev/null || echo staff)"
  user_home_target="$home_dir/my_pi"

  mkdir -p "$user_home_target" || true
  chown "$console_user":"$user_group" "$user_home_target" >/dev/null 2>&1 || true

  # If ${BUCKYOS_ROOT}/home is a real dir (seeded by auto-generated code),
  # migrate its contents into ~/my_pi then replace it with a symlink.
  if [ -e "$BUCKYOS_ROOT/home" ] && [ ! -L "$BUCKYOS_ROOT/home" ]; then
    ditto "$BUCKYOS_ROOT/home" "$user_home_target" >/dev/null 2>&1 || true
    rm -rf "$BUCKYOS_ROOT/home" >/dev/null 2>&1 || true
  fi

  rm -f "$BUCKYOS_ROOT/home" >/dev/null 2>&1 || true
  ln -s "$user_home_target" "$BUCKYOS_ROOT/home" >/dev/null 2>&1 || true

  # Postinstall runs as root; ensure user can read/write under ~/my_pi.
  chown -R "$console_user":"$user_group" "$user_home_target" >/dev/null 2>&1 || true
}
setup_user_home_symlink

if [ -d "$DEFAULTS_DIR" ]; then
  # BEGIN AUTO-GENERATED: data_paths
  if [ ! -e "$BUCKYOS_ROOT/bin/applist.json" ] && [ -e "$DEFAULTS_DIR/bin/applist.json" ]; then
    mkdir -p "$(dirname "$BUCKYOS_ROOT/bin/applist.json")"
    cp -p "$DEFAULTS_DIR/bin/applist.json" "$BUCKYOS_ROOT/bin/applist.json"
  fi
  if [ ! -e "$BUCKYOS_ROOT/etc/node_gateway_info.json" ] && [ -e "$DEFAULTS_DIR/etc/node_gateway_info.json" ]; then
    mkdir -p "$(dirname "$BUCKYOS_ROOT/etc/node_gateway_info.json")"
    cp -p "$DEFAULTS_DIR/etc/node_gateway_info.json" "$BUCKYOS_ROOT/etc/node_gateway_info.json"
  fi
  if [ ! -e "$BUCKYOS_ROOT/etc/user_gateway.yaml" ] && [ -e "$DEFAULTS_DIR/etc/user_gateway.yaml" ]; then
    mkdir -p "$(dirname "$BUCKYOS_ROOT/etc/user_gateway.yaml")"
    cp -p "$DEFAULTS_DIR/etc/user_gateway.yaml" "$BUCKYOS_ROOT/etc/user_gateway.yaml"
  fi
  if [ ! -e "$BUCKYOS_ROOT/etc/post_gateway.yaml" ] && [ -e "$DEFAULTS_DIR/etc/post_gateway.yaml" ]; then
    mkdir -p "$(dirname "$BUCKYOS_ROOT/etc/post_gateway.yaml")"
    cp -p "$DEFAULTS_DIR/etc/post_gateway.yaml" "$BUCKYOS_ROOT/etc/post_gateway.yaml"
  fi
  if [ ! -e "$BUCKYOS_ROOT/etc/node_gateway.json" ] && [ -e "$DEFAULTS_DIR/etc/node_gateway.json" ]; then
    mkdir -p "$(dirname "$BUCKYOS_ROOT/etc/node_gateway.json")"
    cp -p "$DEFAULTS_DIR/etc/node_gateway.json" "$BUCKYOS_ROOT/etc/node_gateway.json"
  fi
  if [ ! -e "$BUCKYOS_ROOT/etc/cyfs_gateway.yaml" ] && [ -e "$DEFAULTS_DIR/etc/cyfs_gateway.yaml" ]; then
    mkdir -p "$(dirname "$BUCKYOS_ROOT/etc/cyfs_gateway.yaml")"
    cp -p "$DEFAULTS_DIR/etc/cyfs_gateway.yaml" "$BUCKYOS_ROOT/etc/cyfs_gateway.yaml"
  fi
  if [ -d "$DEFAULTS_DIR/data" ]; then
    if [ ! -e "$BUCKYOS_ROOT/data" ]; then
      mkdir -p "$BUCKYOS_ROOT/data"
      ditto "$DEFAULTS_DIR/data" "$BUCKYOS_ROOT/data"
    elif [ -d "$BUCKYOS_ROOT/data" ] && [ -z "$(/usr/bin/find "$BUCKYOS_ROOT/data" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]; then
      ditto "$DEFAULTS_DIR/data" "$BUCKYOS_ROOT/data"
    fi
  fi
  if [ -d "$DEFAULTS_DIR/storage" ]; then
    if [ ! -e "$BUCKYOS_ROOT/storage" ]; then
      mkdir -p "$BUCKYOS_ROOT/storage"
      ditto "$DEFAULTS_DIR/storage" "$BUCKYOS_ROOT/storage"
    elif [ -d "$BUCKYOS_ROOT/storage" ] && [ -z "$(/usr/bin/find "$BUCKYOS_ROOT/storage" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]; then
      ditto "$DEFAULTS_DIR/storage" "$BUCKYOS_ROOT/storage"
    fi
  fi
  if [ -d "$DEFAULTS_DIR/local" ]; then
    if [ ! -e "$BUCKYOS_ROOT/local" ]; then
      mkdir -p "$BUCKYOS_ROOT/local"
      ditto "$DEFAULTS_DIR/local" "$BUCKYOS_ROOT/local"
    elif [ -d "$BUCKYOS_ROOT/local" ] && [ -z "$(/usr/bin/find "$BUCKYOS_ROOT/local" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]; then
      ditto "$DEFAULTS_DIR/local" "$BUCKYOS_ROOT/local"
    fi
  fi
  if [ -d "$DEFAULTS_DIR/logs" ]; then
    if [ ! -e "$BUCKYOS_ROOT/logs" ]; then
      mkdir -p "$BUCKYOS_ROOT/logs"
      ditto "$DEFAULTS_DIR/logs" "$BUCKYOS_ROOT/logs"
    elif [ -d "$BUCKYOS_ROOT/logs" ] && [ -z "$(/usr/bin/find "$BUCKYOS_ROOT/logs" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]; then
      ditto "$DEFAULTS_DIR/logs" "$BUCKYOS_ROOT/logs"
    fi
  fi
  # END AUTO-GENERATED: data_paths


  rm -rf "$DEFAULTS_DIR" || true
fi

start_buckyos_service
if ! wait_for_node_daemon; then
  echo "[buckyos] postinstall: node_daemon did not start successfully." >&2
  /usr/bin/env >&2 || true
  ls -l "$PLIST" "${REAL_BUCKYOS_ROOT}/bin/node-daemon/node_daemon" "${REAL_BUCKYOS_ROOT}/logs" "${REAL_BUCKYOS_ROOT}/logs/node_daemon" >&2 || true
  tail -n 200 "$POSTINSTALL_LOG" >&2 || true
  echo "[buckyos] postinstall: check /var/log/buckyos.service.out.log and /var/log/buckyos.service.err.log" >&2
  tail -n 200 /var/log/buckyos.service.out.log >&2 || true
  tail -n 200 /var/log/buckyos.service.err.log >&2 || true
  find "${REAL_BUCKYOS_ROOT}/logs/node_daemon" -maxdepth 1 -type f -print >&2 || true
  launchctl print "system/buckyos.service" >&2 || true
  exit 1
fi

echo "BuckyOS install success, open http://127.0.0.1:3182/index.html to start, ENJOY!"
