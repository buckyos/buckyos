#!/usr/bin/python3

import os
import sys
current_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.append(current_dir)
sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
sys.path.append(os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))))
import util

print("try to kill bucky_file")
util.kill_process("bucky_file")

session_token = os.environ.get("BUCKY_FILE_SESSION_TOKEN", "")
print(f"BUCKY_FILE_SESSION_TOKEN present: {bool(session_token)} len={len(session_token)}")

if os.environ.get("BUCKY_FILE_REQUIRE_RUNTIME") == "1" and not session_token:
    print("BUCKY_FILE_REQUIRE_RUNTIME=1 but session token missing")

util.nohup_start(f"/bin/sh -c '{current_dir}/bucky_file >/tmp/bucky_file.log 2>&1'")
print("bucky_file service started")
