def get_agent_pid_file(appid, username):
    return os.path.join(util.get_app_data_dir(appid, username), ".opendan.pid")


def read_agent_pid(appid, username):
    pid_file = get_agent_pid_file(appid, username)
    if not os.path.exists(pid_file):
        return None
    try:
        with open(pid_file, "r", encoding="utf-8") as f:
            return int(f.read().strip())
    except Exception:
        return None


def is_pid_running(pid):
    if pid is None or pid <= 0:
        return False
    if platform.system() == "Windows":
        cmd = f'tasklist /FI "PID eq {pid}" /FO CSV'
        output = os.popen(cmd).read().strip()
        lines = [line for line in output.splitlines() if line.strip()]
        return len(lines) > 1
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def is_agent_running(appid, username):
    pid = read_agent_pid(appid, username)
    if is_pid_running(pid):
        print(f"Agent '{appid}' is running with pid {pid}.")
        return True
    return False

def is_container_running(container_name,docker_image_name):
    try:
        cmd = f"docker ps -q -f name=^{container_name}$"
        output = os.popen(cmd).read().strip()
        if output:
            print(f"Container '{container_name}' is running.")
            return True
        
        return False
    except Exception as e:
        print(f"Error checking container status: {e}")
        return False
    
def is_docker_image_exist(docker_image_name):
    try:
        cmd = f"docker images -q {docker_image_name}"
        output = os.popen(cmd).read().strip()
        if output:
            return True
    except Exception as e:
        print(f"Error checking docker image status: {e}")
        return False

