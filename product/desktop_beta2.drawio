                    <mxGeometry x="-279.48" y="1375" width="60" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="-VXOMkykjgsclgVf84K5-4" value="几个示范性的运行环境：&lt;div&gt;1)&amp;nbsp; &amp;nbsp;Web Desktop PC&lt;/div&gt;&lt;div&gt;2）Web Desktop 手机(iOS)&lt;/div&gt;&lt;div&gt;3)&amp;nbsp; &amp;nbsp;移动App&lt;/div&gt;&lt;div&gt;4）桌面App&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;每个环境有2个页面：桌面+打开的兼容App的模式&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="-620" y="1140" width="300" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="-VXOMkykjgsclgVf84K5-5" value="" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shadow=0;dashed=0;strokeWidth=1;shape=mxgraph.android.phone2;strokeColor=#c0c0c0;" vertex="1" parent="1">
                    <mxGeometry x="-760" y="1320" width="241.03" height="470" as="geometry"/>
                </mxCell>
                <mxCell id="-VXOMkykjgsclgVf84K5-7" value="Fix Panel1" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-739.48" y="1393" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="-VXOMkykjgsclgVf84K5-8" value="Fix Panel2" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-739.48" y="1468" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="qs3Q-g8kywMPhCm0373b-2" value="" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-739.48" y="1543" width="45" height="45" as="geometry"/>
