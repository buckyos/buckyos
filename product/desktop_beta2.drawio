                    <mxGeometry x="-584.48" y="1543" width="45" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="aX7p0DGKVW2AwgKcj6UA-1" value="Status Bar" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-750" y="1363" width="220" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="aX7p0DGKVW2AwgKcj6UA-2" value="&lt;i&gt;BuckyOS&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCCCCC;" vertex="1" parent="1">
                    <mxGeometry x="-748" y="1363" width="60" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="wv6oJ_jSm3eug91dsApC-1" value="多App并行的几种需求&lt;div&gt;1)&amp;nbsp; 可以随意在运行中的App中切换&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;浏览器: 通过多标签管理切换&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;b&gt;&amp;nbsp;App: 除了iOS手机，都可以用更操作系统的多任务方法来切换已经打开的app。iOS怎么办？&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; Desktop App: 每个App一个窗口&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/div&gt;&lt;div&gt;2）可以在同一个窗口中，同时看到2个App的运行&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; 浏览器:通过WebDesktop的窗口容器实现&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;移动端App：没这个需求？&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Desktop App:每个App一个窗口，通过系统的多窗口&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;实现&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3）随时切换会桌面/使用系统功能&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; 浏览器：通过多标签管理切换，但当Desktop的Tab关闭后，如何快速打开？&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;App: 参考微信小程序的最小化？ 或则提供可变底栏（对全屏App不友好）&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="-748" y="1900" width="300" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="C5vrE4g1DldMqDkBBnUj-1" value="App的几种显示模式&lt;div&gt;1）窗口模式&lt;/div&gt;&lt;div&gt;2）窗口最大化 （移动端默认）&lt;/div&gt;&lt;div&gt;3）全屏显示 / 浏览器全屏显示&lt;/div&gt;&lt;div&gt;4）最小化和退出的区别，在于还能不能被快速的切换到&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;两种窗口化模式都应易于切换回Desktop&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="-370" y="1890" width="300" height="250" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
